# Test: --rm correctly resets deleted flag when file is re-created

export def makeFile (args: List String) =
    def content = "test content"

    # `write` sets `ReRun`, so use a version which allows testing the cache-hit behaviour.
    def do file =
        makeShellPlan "echo '{content}' > {file}" Nil
        | runJobWith defaultRunner
        | getJobOutput

    map do args
    | findFail
    | rmap (\_ Unit)
