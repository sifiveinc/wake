package test

from wake import _

# A job that writes an output file whose name changes every execution (derived
# from a nanosecond timestamp) into a captured output directory. It depends on a
# mutable source file so that changing the source forces the job to re-execute
# with a divergently-named output instead of being reused from cache.
#
# When the job re-executes, wake drops the prior execution's output-file records
# (delete_prior). Because the new execution's file has a different name, the old
# file is never overwritten. Prior to the fix, wake left the old file on disk
# with no database record, so `wake --clean` could not remove it. The fix
# unlinks such stranded files when their records are dropped.
export def go Unit =
    require Pass seed = source "seed.txt"

    makeExecPlan
    ("dash", "-c", "mkdir -p outdir; echo hi > outdir/f.$(date +%s%N).txt; cat seed.txt", Nil)
    (seed, Nil)
    | setPlanLabel "nondeterministic-output"
    | setPlanShare False
    | runJobWith defaultRunner
    | getJobOutputs
