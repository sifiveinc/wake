# xfstests configuration for running against Wake's CAS-backed FUSE filesystem.
#
# This file lives in the wake repo (tests/xfstests/local.config) and is copied
# into the xfstests tree as local.config by tests/tests.wake:runXfstests.
#
# You almost certainly need to edit this file before running any tests; the
# defaults are based on upstream xfstests README.fuse and may not match your
# environment.
#
# Filesystem type under test.
# For FUSE-based filesystems, "fuse" is commonly used.
export FSTYP=fuse

# Devices and mountpoints used by xfstests.
# For FUSE filesystems, TEST_DEV/SCRATCH_DEV names are required but their
# values are often ignored and can be set to arbitrary non-empty strings.
export TEST_DEV=non1
export SCRATCH_DEV=non2

# Mountpoints for the tested filesystem and scratch filesystem inside the
# wakebox /workspace sandbox. Adjust these to point at suitable directories
# in your environment.
export TEST_DIR=/mnt/test
export SCRATCH_MNT=/mnt/scratch

# Optional: further FUSE-specific settings. Uncomment & adjust if you have
# a mount.fuse.<subtype> helper installed for your filesystem.
# export FUSE_SUBTYP=.wakefs
# export MOUNT_OPTIONS="-osource=/some/source/path,allow_other,default_permissions"
# export TEST_FS_MOUNT_OPTS="-osource=/some/other/path,allow_other,default_permissions"
