# xfstests configuration for running against Wake's FUSE filesystem.
#
# This file is copied into the xfstests checkout root as local.config by
# runXfstests before invoking ./check. It is intentionally minimal; the
# defaults are based on upstream xfstests README.fuse and may not match your
# local environment outside the Docker image.

export FSTYP=fuse
export TEST_DEV=non1
export SCRATCH_DEV=non2

# Devices and mountpoints used by xfstests.
# The synthetic non1/non2 names follow upstream README.fuse.
export TEST_DIR=/opt/xfstests-dev/mnt/test
export SCRATCH_MNT=/opt/xfstests-dev/mnt/scratch

# source= points the mount.fuse helper at the real backing directory for each
# mount. Keep these inside the image so they are guaranteed to exist.
export MOUNT_OPTIONS="-osource=/opt/xfstests-dev/mnt/backing/scratch,allow_other,default_permissions"
export TEST_FS_MOUNT_OPTS="-osource=/opt/xfstests-dev/mnt/backing/test,allow_other,default_permissions"
